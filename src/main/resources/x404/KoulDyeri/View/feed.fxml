<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.image.Image?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="x404.KoulDyeri.View.FeedView"
            style="-fx-background-color: #f0f2f5;">

    <!-- ==================== HEADER MODERNE ==================== -->
    <top>
        <VBox style="-fx-background-color: white; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 8, 0, 0, 2);">
            <!-- Barre de navigation principale -->
            <HBox alignment="CENTER_LEFT" spacing="20" style="-fx-padding: 12 24; -fx-background-color: white;">

                <!-- Logo + Titre -->
                <HBox alignment="CENTER_LEFT" spacing="12">
                    <!-- Logo image -->
                    <ImageView fitHeight="45" fitWidth="45" preserveRatio="true">
                        <image>
                            <Image url="@logo.png"/>
                        </image>
                    </ImageView>
                    <Label text="KoulDyeri"
                           style="-fx-font-family: 'Segoe UI Semibold'; -fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #d32f2f;"/>
                </HBox>

                <!-- Barre de recherche -->
                <TextField promptText="🔍 Rechercher une recette..."
                           prefWidth="350"
                           style="-fx-background-color: #f0f2f5; -fx-background-radius: 25; -fx-padding: 10 20; -fx-font-size: 14px; -fx-border-width: 0;"/>

                <Region HBox.hgrow="ALWAYS"/>

                <!-- Menu navigation -->
                <HBox spacing="5">
                    <Button text="🏠"
                            style="-fx-background-color: #e7f3ff; -fx-text-fill: #1877f2; -fx-font-size: 24px; -fx-background-radius: 10; -fx-padding: 8 16; -fx-cursor: hand; -fx-border-width: 0;"/>
                    <Button text="👥"
                            style="-fx-background-color: transparent; -fx-text-fill: #65676b; -fx-font-size: 24px; -fx-background-radius: 10; -fx-padding: 8 16; -fx-cursor: hand;"/>
                    <Button text="🔔"
                            style="-fx-background-color: transparent; -fx-text-fill: #65676b; -fx-font-size: 24px; -fx-background-radius: 10; -fx-padding: 8 16; -fx-cursor: hand;"/>
                </HBox>

                <!-- Avatar utilisateur -->
                <HBox alignment="CENTER" spacing="10">
                    <Circle radius="20" fill="#ffccbc" stroke="#d32f2f" strokeWidth="2"/>
                    <Label text="Mon Profil" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #050505;"/>
                    <Button text="▼"
                            style="-fx-background-color: #f0f2f5; -fx-background-radius: 20; -fx-padding: 4 10; -fx-font-size: 12px; -fx-cursor: hand;"/>
                </HBox>
            </HBox>

            <Separator style="-fx-background-color: #dadde1;"/>
        </VBox>
    </top>

    <!-- ==================== CONTENU PRINCIPAL ==================== -->
    <center>
        <HBox spacing="0" style="-fx-padding: 0;">

            <!-- ========== SIDEBAR GAUCHE NOIRE ========== -->
            <VBox spacing="0" prefWidth="280"
                  style="-fx-background-color: #1a1a1a; -fx-padding: 20 0 20 0;">

                <!-- Logo dans la sidebar -->
                <VBox alignment="CENTER" style="-fx-padding: 0 0 20 0;">
                    <ImageView fitHeight="60" fitWidth="60" preserveRatio="true">
                        <image>
                            <Image url="@logo.png"/>
                        </image>
                    </ImageView>
                    <Label text="KoulDyeri"
                           style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: white; -fx-padding: 8 0 0 0;"/>
                </VBox>

                <Separator style="-fx-background-color: #333333; -fx-padding: 0 20;"/>

                <!-- Menu -->
                <VBox spacing="5" style="-fx-padding: 20;">
                    <Label text="📋 MENU"
                           style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #888888; -fx-padding: 0 0 10 15;"/>

                    <Button text="🏠 Fil d'actualité" maxWidth="Infinity" alignment="CENTER_LEFT"
                            style="-fx-background-color: #d32f2f; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 12 15; -fx-cursor: hand;"/>

                    <Button text="👥 Amis" maxWidth="Infinity" alignment="CENTER_LEFT"
                            style="-fx-background-color: transparent; -fx-text-fill: #cccccc; -fx-font-size: 14px; -fx-background-radius: 8; -fx-padding: 12 15; -fx-cursor: hand;"/>

                    <Button text="📚 Mes recettes" maxWidth="Infinity" alignment="CENTER_LEFT"
                            style="-fx-background-color: transparent; -fx-text-fill: #cccccc; -fx-font-size: 14px; -fx-background-radius: 8; -fx-padding: 12 15; -fx-cursor: hand;"/>

                    <Button text="⭐ Favoris" maxWidth="Infinity" alignment="CENTER_LEFT"
                            style="-fx-background-color: transparent; -fx-text-fill: #cccccc; -fx-font-size: 14px; -fx-background-radius: 8; -fx-padding: 12 15; -fx-cursor: hand;"/>

                    <Button text="📊 Statistiques" maxWidth="Infinity" alignment="CENTER_LEFT"
                            style="-fx-background-color: transparent; -fx-text-fill: #cccccc; -fx-font-size: 14px; -fx-background-radius: 8; -fx-padding: 12 15; -fx-cursor: hand;"/>
                </VBox>

                <Separator style="-fx-background-color: #333333; -fx-padding: 0 20;"/>

                <!-- Tendances -->
                <VBox spacing="10" style="-fx-padding: 20;">
                    <Label text="🔥 TENDANCES"
                           style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #888888;"/>

                    <VBox spacing="8" style="-fx-padding: 12; -fx-background-color: #2a2a2a; -fx-background-radius: 10;">
                        <Label text="#CouscousMaison"
                               style="-fx-font-size: 13px; -fx-text-fill: #ff6b6b; -fx-cursor: hand; -fx-font-weight: bold;"/>
                        <Label text="#RecetteTunisienne"
                               style="-fx-font-size: 13px; -fx-text-fill: #ff6b6b; -fx-cursor: hand; -fx-font-weight: bold;"/>
                        <Label text="#Pâtisserie"
                               style="-fx-font-size: 13px; -fx-text-fill: #ff6b6b; -fx-cursor: hand; -fx-font-weight: bold;"/>
                    </VBox>
                </VBox>

                <!-- Spacer pour pousser le footer en bas -->
                <Region VBox.vgrow="ALWAYS"/>

                <!-- Mini footer sidebar -->
                <VBox spacing="5" style="-fx-padding: 20; -fx-border-color: #333333; -fx-border-width: 1 0 0 0;">
                    <Label text="© 2026 KoulDyeri"
                           style="-fx-font-size: 11px; -fx-text-fill: #666666; -fx-font-style: italic;"/>
                    <Label text="Tous droits réservés"
                           style="-fx-font-size: 10px; -fx-text-fill: #555555;"/>
                </VBox>
            </VBox>

            <!-- ========== FEED CENTRAL ========== -->
            <VBox spacing="20" HBox.hgrow="ALWAYS" maxWidth="680" style="-fx-padding: 20;">

                <!-- ===== COMPOSER (Créer publication) ===== -->
                <VBox spacing="15"
                      style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 8, 0, 0, 2);">

                    <!-- Titre section -->
                    <HBox alignment="CENTER_LEFT" spacing="12">
                        <Circle radius="24" fill="#ffccbc" stroke="#d32f2f" strokeWidth="2"/>
                        <TextField fx:id="titleField"
                                   promptText="Titre de votre recette..."
                                   prefWidth="500"
                                   style="-fx-background-color: #f0f2f5; -fx-background-radius: 25; -fx-padding: 12 20; -fx-font-size: 14px; -fx-border-width: 0;"/>
                    </HBox>

                    <!-- Zone de texte -->
                    <TextArea fx:id="contentField"
                              promptText="Partagez votre recette, astuce ou avis culinaire..."
                              wrapText="true"
                              prefRowCount="3"
                              style="-fx-background-color: #f0f2f5; -fx-background-radius: 12; -fx-border-width: 0; -fx-padding: 15; -fx-font-size: 15px; -fx-text-fill: #050505;"/>

                    <!-- Séparateur -->
                    <Separator style="-fx-background-color: #e4e6eb;"/>

                    <!-- Actions -->
                    <HBox spacing="10" alignment="CENTER">
                        <Button fx:id="uploadImageBtn" text="📷 Photo/Vidéo"
                                maxWidth="Infinity" HBox.hgrow="ALWAYS"
                                style="-fx-background-color: transparent; -fx-text-fill: #65676b; -fx-font-size: 14px; -fx-font-weight: 600; -fx-background-radius: 8; -fx-padding: 10; -fx-cursor: hand; -fx-border-width: 0;"/>
                        <Button text="😊 Humeur"
                                maxWidth="Infinity" HBox.hgrow="ALWAYS"
                                style="-fx-background-color: transparent; -fx-text-fill: #65676b; -fx-font-size: 14px; -fx-font-weight: 600; -fx-background-radius: 8; -fx-padding: 10; -fx-cursor: hand;"/>
                        <Button text="📍 Lieu"
                                maxWidth="Infinity" HBox.hgrow="ALWAYS"
                                style="-fx-background-color: transparent; -fx-text-fill: #65676b; -fx-font-size: 14px; -fx-font-weight: 600; -fx-background-radius: 8; -fx-padding: 10; -fx-cursor: hand;"/>
                    </HBox>

                    <Button fx:id="addPostBtn" text="Publier" maxWidth="Infinity"
                            style="-fx-background-color: #d32f2f; -fx-text-fill: white; -fx-font-size: 16px; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 12 0; -fx-cursor: hand;"/>
                </VBox>

                <!-- ===== LISTE DES POSTS ===== -->
                <ListView fx:id="postList"
                          VBox.vgrow="ALWAYS"
                          style="-fx-background-color: transparent; -fx-border-width: 0; -fx-background-insets: 0; -fx-padding: 0;"/>
            </VBox>

            <!-- ========== SIDEBAR DROITE ========== -->
            <VBox spacing="15" prefWidth="300" style="-fx-padding: 20;">
                <!-- Suggestions -->
                <VBox spacing="12"
                      style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 15; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 6, 0, 0, 2);">
                    <Label text="👥 Suggestions d'amis" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #050505;"/>

                    <!-- Ami suggestion 1 -->
                    <HBox spacing="10" alignment="CENTER_LEFT">
                        <Circle radius="20" fill="#ffccbc"/>
                        <VBox spacing="2" HBox.hgrow="ALWAYS">
                            <Label text="Fatima Zahra" style="-fx-font-size: 13px; -fx-font-weight: bold;"/>
                            <Label text="12 amis en commun" style="-fx-font-size: 12px; -fx-text-fill: #65676b;"/>
                        </VBox>
                        <Button text="➕"
                                style="-fx-background-color: #e7f3ff; -fx-text-fill: #1877f2; -fx-font-size: 16px; -fx-background-radius: 6; -fx-padding: 4 10; -fx-cursor: hand;"/>
                    </HBox>

                    <!-- Ami suggestion 2 -->
                    <HBox spacing="10" alignment="CENTER_LEFT">
                        <Circle radius="20" fill="#c8e6c9"/>
                        <VBox spacing="2" HBox.hgrow="ALWAYS">
                            <Label text="Ahmed Ben Ali" style="-fx-font-size: 13px; -fx-font-weight: bold;"/>
                            <Label text="8 amis en commun" style="-fx-font-size: 12px; -fx-text-fill: #65676b;"/>
                        </VBox>
                        <Button text="➕"
                                style="-fx-background-color: #e7f3ff; -fx-text-fill: #1877f2; -fx-font-size: 16px; -fx-background-radius: 6; -fx-padding: 4 10; -fx-cursor: hand;"/>
                    </HBox>
                </VBox>

                <!-- Anniversaires -->
                <VBox spacing="10"
                      style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 15; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 6, 0, 0, 2);">
                    <Label text="🎂 Anniversaires" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #050505;"/>
                    <Label text="Leila fête son anniversaire aujourd'hui !"
                           wrapText="true"
                           style="-fx-font-size: 13px; -fx-text-fill: #050505;"/>
                </VBox>

                <!-- Publicité -->
                <VBox spacing="8"
                      style="-fx-background-color: #fff3e0; -fx-background-radius: 12; -fx-padding: 15; -fx-border-color: #ffb74d; -fx-border-width: 1; -fx-border-radius: 12;">
                    <Label text="📢 Sponsorisé" style="-fx-font-size: 11px; -fx-text-fill: #8d6e63;"/>
                    <Label text="Nouveau livre de recettes !" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #bf360c;"/>
                    <Label text="50 recettes traditionnelles tunisiennes"
                           wrapText="true"
                           style="-fx-font-size: 12px; -fx-text-fill: #5d4037;"/>
                    <Button text="En savoir plus" maxWidth="Infinity"
                            style="-fx-background-color: #d32f2f; -fx-text-fill: white; -fx-font-size: 12px; -fx-font-weight: bold; -fx-background-radius: 6; -fx-padding: 6; -fx-cursor: hand;"/>
                </VBox>
            </VBox>

        </HBox>
    </center>

    <!-- ==================== FOOTER ==================== -->
    <bottom>
        <HBox alignment="CENTER" spacing="20"
              style="-fx-padding: 20; -fx-background-color: white; -fx-border-color: #dadde1; -fx-border-width: 1 0 0 0;">
            <Label text="À propos" style="-fx-text-fill: #65676b; -fx-font-size: 12px; -fx-cursor: hand;"/>
            <Label text="•" style="-fx-text-fill: #65676b;"/>
            <Label text="Aide" style="-fx-text-fill: #65676b; -fx-font-size: 12px; -fx-cursor: hand;"/>
            <Label text="•" style="-fx-text-fill: #65676b;"/>
            <Label text="Conditions" style="-fx-text-fill: #65676b; -fx-font-size: 12px; -fx-cursor: hand;"/>
            <Label text="•" style="-fx-text-fill: #65676b;"/>
            <Label text="Confidentialité" style="-fx-text-fill: #65676b; -fx-font-size: 12px; -fx-cursor: hand;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label text="KoulDyeri © 2026" style="-fx-text-fill: #8d6e63; -fx-font-size: 12px; -fx-font-weight: bold;"/>
        </HBox>
    </bottom>

</BorderPane>