<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="controller.ProduitFController"
            style="-fx-background-color: #f5f7fa;">

    <top>
        <HBox spacing="12" alignment="CENTER_LEFT"
              style="-fx-padding: 12 15; -fx-background-color: white; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 12, 0, 0, 3);">
            <Label text="📦 Produits" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #1a1a1a;"/>

            <Region HBox.hgrow="ALWAYS"/>

            <Button text="🛒 Commander" onAction="#goCommandeF"
                    style="-fx-background-color: white; -fx-text-fill: #CE1126; -fx-font-size: 14px; -fx-padding: 10 18; -fx-background-radius: 10; -fx-border-color: #CE1126; -fx-border-width: 2; -fx-cursor: hand;"/>
        </HBox>
    </top>

    <center>
        <VBox spacing="15" style="-fx-padding: 20;">

            <VBox spacing="12"
                  style="-fx-background-color: white; -fx-background-radius: 15; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 20, 0, 0, 5); -fx-padding: 18;"
                  VBox.vgrow="ALWAYS">

                <Label text="Liste des produits disponibles"
                       style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #1a1a1a;"/>

                <TableView fx:id="productsTable" VBox.vgrow="ALWAYS"
                           style="-fx-background-color: transparent; -fx-background-radius: 10;">
                    <columns>
                        <TableColumn fx:id="colId" text="ID" prefWidth="80" style="-fx-alignment: CENTER;"/>
                        <TableColumn fx:id="colName" text="Nom" prefWidth="320"/>
                        <TableColumn fx:id="colPrice" text="Prix" prefWidth="160" style="-fx-alignment: CENTER;"/>
                    </columns>
                </TableView>

            </VBox>

        </VBox>
    </center>

</BorderPane>
