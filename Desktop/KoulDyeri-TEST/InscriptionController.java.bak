    // Patterns de validation
    private static final Pattern EMAIL_PATTERN =
            Pattern.compile("^[A-Za-z0-9+_.-]+@[A-Za-z0-9.-]+\\.[A-Za-z]{2,}$");
    private static final Pattern NOM_PATTERN =
            Pattern.compile("^[a-zA-ZÀ-ÿ\\s'-]{2,50}$");
    private static final Pattern PASSWORD_PATTERN =
            Pattern.compile("^(?=.*[A-Za-z])(?=.*\\d)[A-Za-z\\d]{6,}$");

    @FXML
    public void initialize() {
        setupRegions();
        setupRoles();
        setupValidationListeners();
        setupAnimations();
        setupDatePicker();
    }

    private void setupRegions() {
        regionComboBox.getItems().addAll(
                "Ariana", "Béja", "Ben Arous", "Bizerte", "Gabès", "Gafsa",
                "Jendouba", "Kairouan", "Kasserine", "Kebili", "Kef", "Mahdia",
                "Manouba", "Medenine", "Monastir", "Nabeul", "Sfax",
                "Sidi Bouzid", "Siliana", "Sousse", "Tataouine",
                "Tozeur", "Tunis", "Zaghouan"
        );
        regionComboBox.setPromptText("Sélectionnez votre région");
    }

    private void setupRoles() {
        roleComboBox.getItems().addAll("Utilisateur", "Femme Vendeuse");
        roleComboBox.setValue("Utilisateur");
        roleComboBox.setPromptText("Choisissez votre rôle");
    }

    private void setupDatePicker() {
        dateNaissancePicker.setPromptText("JJ/MM/AAAA");
        dateNaissancePicker.setConverter(new javafx.util.StringConverter<LocalDate>() {
            DateTimeFormatter formatter = DateTimeFormatter.ofPattern("dd/MM/yyyy");

            @Override
            public String toString(LocalDate date) {
                return date != null ? formatter.format(date) : "";
            }

            @Override
            public LocalDate fromString(String string) {
                return string != null && !string.isEmpty() ? LocalDate.parse(string, formatter) : null;
            }
        });
    }

    private void setupAnimations() {
        if (btnInscription != null) {
            DropShadow shadow = new DropShadow();
            shadow.setColor(Color.rgb(206, 17, 38, 0.3));
            shadow.setRadius(10);
            btnInscription.setEffect(shadow);

            btnInscription.setOnMouseEntered(e -> {
                ScaleTransition st = new ScaleTransition(Duration.millis(200), btnInscription);
                st.setToX(1.02);
                st.setToY(1.02);
                st.play();
            });

            btnInscription.setOnMouseExited(e -> {
                ScaleTransition st = new ScaleTransition(Duration.millis(200), btnInscription);
                st.setToX(1.0);
                st.setToY(1.0);
                st.play();
            });
        }
    }

    private void setupValidationListeners() {
        nomField.textProperty().addListener((obs, old, newVal) -> {
            clearMessage();
            if (!newVal.isEmpty()) {
                if (!NOM_PATTERN.matcher(newVal).matches()) {
                    setFieldError(nomField, "❌ Format invalide");
                } else {
                    setFieldSuccess(nomField);
                }
            } else {
                resetFieldStyle(nomField);
            }
        });

        emailField.textProperty().addListener((obs, old, newVal) -> {
            clearMessage();
            if (!newVal.isEmpty()) {
                if (!EMAIL_PATTERN.matcher(newVal).matches()) {
                    setFieldError(emailField, "❌ Email invalide");
                } else {
                    setFieldSuccess(emailField);
                }
            } else {
                resetFieldStyle(emailField);
            }
        });

        passwordField.textProperty().addListener((obs, old, newVal) -> {
            clearMessage();
            if (!newVal.isEmpty()) {
                if (newVal.length() < 6) {
                    setFieldError(passwordField, "❌ Minimum 6 caractères");
                } else if (!newVal.matches(".*\\d.*")) {
                    setFieldError(passwordField, "❌ Doit contenir un chiffre");
                } else {
                    setFieldSuccess(passwordField);
                }
            } else {
                resetFieldStyle(passwordField);
            }
        });

        dateNaissancePicker.valueProperty().addListener((obs, old, newVal) -> {
            clearMessage();
            if (newVal != null) {
                if (!validerAge(newVal)) {
                    setFieldError(dateNaissancePicker, "❌ Âge minimum 13 ans");
                } else {
                    setFieldSuccess(dateNaissancePicker);
                }
            } else {
                resetFieldStyle(dateNaissancePicker);
            }
        });

        regionComboBox.valueProperty().addListener((obs, old, newVal) -> {
            clearMessage();
            if (newVal != null && !newVal.isEmpty()) {
                setFieldSuccess(regionComboBox);
            } else {
                resetFieldStyle(regionComboBox);
            }
        });
    }

    private void setFieldError(Control field, String tooltip) {
        field.setStyle("-fx-border-color: #ff6b6b; -fx-border-width: 2; -fx-border-radius: 8;");
        if (!(field instanceof ComboBox)) {
            field.setTooltip(new Tooltip(tooltip));
        }
    }

    private void setFieldSuccess(Control field) {
        field.setStyle("-fx-border-color: #51cf66; -fx-border-width: 2; -fx-border-radius: 8;");
        field.setTooltip(null);
    }

    private void resetFieldStyle(Control field) {
        field.setStyle("-fx-border-color: #d6c6a5; -fx-border-width: 1.2; -fx-border-radius: 8;");
        field.setTooltip(null);
    }

    private void clearMessage() {
        messageLabel.setGraphic(null);
        messageLabel.setText("");
    }

    private Image loadLogo() {
        String[] possiblePaths = {
                "/x404/kouldyeri/images/logo.png",
                "/images/logo.png",
                "/logo.png"
        };

        for (String path : possiblePaths) {
            try {
                InputStream logoStream = getClass().getResourceAsStream(path);
                if (logoStream != null) {
                    System.out.println("✅ Logo trouvé dans : " + path);
                    return new Image(logoStream);
                }
            } catch (Exception e) {
                System.err.println("Tentative échouée pour : " + path);
            }
        }

        String[] filePaths = {
                "src/main/resources/x404/kouldyeri/images/logo.png",
                "src/main/resources/images/logo.png"
        };

        for (String path : filePaths) {
            try {
                File logoFile = new File(path);
                if (logoFile.exists()) {
                    System.out.println("✅ Logo trouvé dans : " + logoFile.getAbsolutePath());
                    return new Image(logoFile.toURI().toString());
                }
            } catch (Exception e) {
                System.err.println("Tentative échouée pour : " + path);
            }
        }

        System.err.println("❌ Logo non trouvé dans aucun des chemins");
        return null;
    }

    private ImageView createLogoIcon() {
        try {
            Image logoImage = loadLogo();
            if (logoImage != null) {
                ImageView icon = new ImageView(logoImage);
                icon.setFitWidth(20);
                icon.setFitHeight(20);
                icon.setPreserveRatio(true);
                return icon;
            }
        } catch (Exception e) {
            System.err.println("Impossible de charger l'icône: " + e.getMessage());
        }
        return null;
    }

    @FXML
    private void choisirPhoto() {
        FileChooser chooser = new FileChooser();
        chooser.setTitle("Choisir une photo de profil");
        chooser.getExtensionFilters().addAll(
                new FileChooser.ExtensionFilter("Images", "*.png", "*.jpg", "*.jpeg", "*.gif", "*.bmp")
        );

        File file = chooser.showOpenDialog(nomField.getScene().getWindow());
        if (file != null) {
            long fileSizeInMB = file.length() / (1024 * 1024);
            if (fileSizeInMB > MAX_FILE_SIZE_MB) {
                showAlertWithLogo(Alert.AlertType.WARNING, "⚠️ Fichier trop volumineux",
                        String.format("La taille de l'image ne doit pas dépasser %d MB.\nTaille actuelle: %d MB",
                                MAX_FILE_SIZE_MB, fileSizeInMB));
                return;
            }

            try {
                photoPath = file.getAbsolutePath();
                Image image = new Image(file.toURI().toString());
                photoImageView.setImage(image);

                ScaleTransition st = new ScaleTransition(Duration.millis(300), photoImageView);
                st.setFromX(0.5);
                st.setFromY(0.5);
                st.setToX(1.0);
                st.setToY(1.0);
                st.play();

                showTemporaryMessage("✅ Photo chargée avec succès", "#51cf66");
            } catch (Exception e) {
                showAlertWithLogo(Alert.AlertType.ERROR, "❌ Erreur",
                        "Impossible de charger l'image. Vérifiez le format.");
            }
        }
    }

    private void showTemporaryMessage(String message, String color) {
        messageLabel.setGraphic(createLogoIcon());
        messageLabel.setText(message);
        messageLabel.setStyle("-fx-text-fill: " + color + "; -fx-font-weight: bold;");
        messageLabel.setGraphicTextGap(8);

        FadeTransition ft = new FadeTransition(Duration.seconds(3), messageLabel);
        ft.setFromValue(1.0);
        ft.setToValue(0.0);
        ft.setDelay(Duration.seconds(2));
        ft.play();
    }

