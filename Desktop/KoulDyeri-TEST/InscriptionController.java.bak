    private void showSuccessSplash(String nom, Runnable onComplete) {
        Stage splashStage = new Stage();
        splashStage.initStyle(StageStyle.TRANSPARENT);
        splashStage.initModality(javafx.stage.Modality.APPLICATION_MODAL);

        VBox splashContainer = new VBox(30);
        splashContainer.setAlignment(Pos.CENTER);
        splashContainer.setPadding(new Insets(60, 100, 60, 100));
        splashContainer.setStyle(
                "-fx-background-color: linear-gradient(135deg, #51cf66 0%, #37b24d 50%, #2f9e44 100%);" +
                        "-fx-background-radius: 35;" +
                        "-fx-effect: dropshadow(gaussian, rgba(0, 0, 0, 0.6), 40, 0, 0, 15);"
        );

        try {
            Image logoImage = loadLogo();
            if (logoImage != null) {
                ImageView logoView = new ImageView(logoImage);
                logoView.setFitWidth(150);
                logoView.setFitHeight(150);
                logoView.setPreserveRatio(true);

                ScaleTransition scaleTransition = new ScaleTransition(Duration.seconds(0.8), logoView);
                scaleTransition.setFromX(0.0);
                scaleTransition.setFromY(0.0);
                scaleTransition.setToX(1.0);
                scaleTransition.setToY(1.0);
                scaleTransition.setInterpolator(Interpolator.EASE_OUT);

                RotateTransition rotateTransition = new RotateTransition(Duration.seconds(1.2), logoView);
                rotateTransition.setFromAngle(0);
                rotateTransition.setToAngle(360);
                rotateTransition.setInterpolator(Interpolator.EASE_BOTH);

                ParallelTransition parallelTransition = new ParallelTransition(scaleTransition, rotateTransition);
                parallelTransition.play();

                splashContainer.getChildren().add(logoView);
            } else {
                Label logoText = new Label("✓");
                logoText.setStyle("-fx-font-size: 120px; -fx-text-fill: white; -fx-font-weight: bold;");
                splashContainer.getChildren().add(logoText);
            }
        } catch (Exception e) {
            System.err.println("Impossible de charger le logo: " + e.getMessage());
        }

        Label congratsLabel = new Label("Félicitations !");
        congratsLabel.setStyle(
                "-fx-font-size: 38px;" +
                        "-fx-font-weight: bold;" +
                        "-fx-text-fill: white;" +
                        "-fx-effect: dropshadow(gaussian, rgba(0, 0, 0, 0.7), 20, 0, 0, 8);"
        );
        congratsLabel.setOpacity(0);

        FadeTransition fadeInCongrats = new FadeTransition(Duration.seconds(0.8), congratsLabel);
        fadeInCongrats.setFromValue(0.0);
        fadeInCongrats.setToValue(1.0);
        fadeInCongrats.setDelay(Duration.seconds(0.6));

        splashContainer.getChildren().add(congratsLabel);

        Label userNameLabel = new Label(nom);
        userNameLabel.setStyle(
                "-fx-font-size: 30px;" +
                        "-fx-font-weight: 600;" +
                        "-fx-text-fill: #FFD700;" +
                        "-fx-effect: dropshadow(gaussian, rgba(0, 0, 0, 0.6), 15, 0, 0, 6);"
        );
        userNameLabel.setOpacity(0);

        FadeTransition fadeInName = new FadeTransition(Duration.seconds(0.8), userNameLabel);
        fadeInName.setFromValue(0.0);
        fadeInName.setToValue(1.0);
        fadeInName.setDelay(Duration.seconds(1.2));

        TranslateTransition translateName = new TranslateTransition(Duration.seconds(0.8), userNameLabel);
        translateName.setFromY(30);
        translateName.setToY(0);
        translateName.setDelay(Duration.seconds(1.2));

        ParallelTransition nameAnimation = new ParallelTransition(fadeInName, translateName);

        splashContainer.getChildren().add(userNameLabel);

        Label successLabel = new Label("Votre compte est prêt !");
        successLabel.setStyle(
                "-fx-font-size: 22px;" +
                        "-fx-font-weight: normal;" +
                        "-fx-text-fill: white;"
        );
        successLabel.setOpacity(0);

        FadeTransition fadeInSuccess = new FadeTransition(Duration.seconds(0.8), successLabel);
        fadeInSuccess.setFromValue(0.0);
        fadeInSuccess.setToValue(1.0);
        fadeInSuccess.setDelay(Duration.seconds(1.8));

        splashContainer.getChildren().add(successLabel);

        HBox bonusBox = new HBox(10);
        bonusBox.setAlignment(Pos.CENTER);

        Label starLabel = new Label("⭐");
        starLabel.setStyle("-fx-font-size: 24px;");

        Label bonusLabel = new Label("+ " + BONUS_POINTS + " Points de Bienvenue !");
        bonusLabel.setStyle(
                "-fx-font-size: 20px;" +
                        "-fx-font-weight: bold;" +
                        "-fx-text-fill: #FFD700;" +
                        "-fx-effect: dropshadow(gaussian, rgba(0, 0, 0, 0.7), 15, 0, 0, 5);"
        );

        bonusBox.getChildren().addAll(starLabel, bonusLabel);
        bonusBox.setOpacity(0);

        FadeTransition fadeInBonus = new FadeTransition(Duration.seconds(0.8), bonusBox);
        fadeInBonus.setFromValue(0.0);
        fadeInBonus.setToValue(1.0);
        fadeInBonus.setDelay(Duration.seconds(2.2));

        ScaleTransition scaleBonus = new ScaleTransition(Duration.seconds(0.5), bonusBox);
        scaleBonus.setFromX(0.5);
        scaleBonus.setFromY(0.5);
        scaleBonus.setToX(1.0);
        scaleBonus.setToY(1.0);
        scaleBonus.setDelay(Duration.seconds(2.2));

        ParallelTransition bonusAnimation = new ParallelTransition(fadeInBonus, scaleBonus);

        splashContainer.getChildren().add(bonusBox);

        Label subtitleLabel = new Label("Redirection vers la page de connexion...");
        subtitleLabel.setStyle(
                "-fx-font-size: 14px;" +
                        "-fx-font-weight: normal;" +
                        "-fx-text-fill: rgba(255, 255, 255, 0.9);"
        );
        subtitleLabel.setOpacity(0);

        FadeTransition fadeInSubtitle = new FadeTransition(Duration.seconds(0.6), subtitleLabel);
        fadeInSubtitle.setFromValue(0.0);
        fadeInSubtitle.setToValue(1.0);
        fadeInSubtitle.setDelay(Duration.seconds(2.8));

        splashContainer.getChildren().add(subtitleLabel);

        ProgressBar progressBar = new ProgressBar(0);
        progressBar.setPrefWidth(300);
        progressBar.setStyle(
                "-fx-accent: #FFD700;" +
                        "-fx-background-color: rgba(255, 255, 255, 0.3);" +
                        "-fx-background-radius: 10;"
        );
        progressBar.setOpacity(0);

        FadeTransition fadeInProgress = new FadeTransition(Duration.seconds(0.4), progressBar);
        fadeInProgress.setFromValue(0.0);
        fadeInProgress.setToValue(1.0);
        fadeInProgress.setDelay(Duration.seconds(3.2));

        splashContainer.getChildren().add(progressBar);

        Timeline progressTimeline = new Timeline(
                new KeyFrame(Duration.ZERO, new KeyValue(progressBar.progressProperty(), 0)),
                new KeyFrame(Duration.seconds(4), new KeyValue(progressBar.progressProperty(), 1))
        );

        Scene splashScene = new Scene(splashContainer);
        splashScene.setFill(javafx.scene.paint.Color.TRANSPARENT);
        splashStage.setScene(splashScene);
        splashStage.centerOnScreen();

        fadeInCongrats.play();
        nameAnimation.play();
        fadeInSuccess.play();
        bonusAnimation.play();
        fadeInSubtitle.play();
        fadeInProgress.play();
        progressTimeline.play();

        Timeline closeTimeline = new Timeline(new KeyFrame(Duration.seconds(4), event -> {
            FadeTransition fadeOut = new FadeTransition(Duration.seconds(0.5), splashContainer);
            fadeOut.setFromValue(1.0);
            fadeOut.setToValue(0.0);
            fadeOut.setOnFinished(e -> {
                splashStage.close();
                if (onComplete != null) {
                    onComplete.run();
                }
            });
            fadeOut.play();
        }));
        closeTimeline.play();

        splashStage.show();
    }

    @FXML
    private void handleInscription() {
        clearMessage();

        String nom = nomField.getText().trim();
        String email = emailField.getText().trim();
        String password = passwordField.getText();
        LocalDate dateNaissance = dateNaissancePicker.getValue();
        String region = regionComboBox.getValue();
        String role = roleComboBox.getValue();

        ValidationResult validation = validateAllFields(nom, email, password, dateNaissance, region, role);

        if (!validation.isValid()) {
            showAlertWithLogo(Alert.AlertType.ERROR, "❌ Erreurs de validation",
                    validation.getErrorMessage());
            highlightInvalidFields(validation);
            return;
        }

        if (emailExiste(email)) {
            showAlertWithLogo(Alert.AlertType.ERROR, "📧 Email déjà utilisé",
                    "Cet email est déjà associé à un compte.\n\nVeuillez utiliser un autre email.");
            setFieldError(emailField, "Email déjà utilisé");
            emailField.requestFocus();
            return;
        }

        proceedWithRegistration(nom, email, password, dateNaissance, region, role);
    }

    private ValidationResult validateAllFields(String nom, String email, String password,
                                               LocalDate dateNaissance, String region, String role) {
        StringBuilder errors = new StringBuilder();
        boolean isValid = true;

        if (nom.isEmpty()) {
            errors.append("• Le nom est obligatoire\n");
            isValid = false;
        } else if (!NOM_PATTERN.matcher(nom).matches()) {
            errors.append("• Le nom doit contenir entre 2 et 50 lettres uniquement\n");
            isValid = false;
        }

        if (email.isEmpty()) {
            errors.append("• L'email est obligatoire\n");
            isValid = false;
        } else if (!EMAIL_PATTERN.matcher(email).matches()) {
            errors.append("• Format d'email invalide (ex: nom@domaine.com)\n");
            isValid = false;
        }

        if (password.isEmpty()) {
            errors.append("• Le mot de passe est obligatoire\n");
            isValid = false;
        } else if (password.length() < 6) {
            errors.append("• Le mot de passe doit contenir au moins 6 caractères\n");
            isValid = false;
        } else if (!password.matches(".*\\d.*")) {
            errors.append("• Le mot de passe doit contenir au moins un chiffre\n");
            isValid = false;
        }

        if (dateNaissance == null) {
            errors.append("• La date de naissance est obligatoire\n");
            isValid = false;
        } else if (!validerAge(dateNaissance)) {
            errors.append("• Vous devez avoir au moins 13 ans\n");
            isValid = false;
        }

        if (region == null || region.isEmpty()) {
            errors.append("• Veuillez sélectionner une région\n");
            isValid = false;
        }

        if (role == null || role.isEmpty()) {
            errors.append("• Veuillez sélectionner un rôle\n");
            isValid = false;
        }

        return new ValidationResult(isValid, errors.toString());
    }

    private void highlightInvalidFields(ValidationResult validation) {
        // Les champs sont déjà stylisés par les listeners
    }

    private void proceedWithRegistration(String nom, String email, String password,
                                         LocalDate dateNaissance, String region, String role) {
        showLoadingState(true);

        try (Connection conn = DBConnection.getConnection()) {
            String sql = """
                INSERT INTO utilisateur
                (nom, email, motDePasse, dateNaissance, region, role, photo)
                VALUES (?, ?, ?, ?, ?, ?, ?)
            """;

            PreparedStatement pst = conn.prepareStatement(sql, Statement.RETURN_GENERATED_KEYS);
            pst.setString(1, nom);
            pst.setString(2, email);
            pst.setString(3, password);
            pst.setDate(4, java.sql.Date.valueOf(dateNaissance));
            pst.setString(5, region);
            pst.setString(6, role.equals("Femme Vendeuse") ? "admin" : "user");
            pst.setString(7, photoPath);

            int rowsAffected = pst.executeUpdate();

            if (rowsAffected > 0) {
                ResultSet generatedKeys = pst.getGeneratedKeys();
                if (generatedKeys.next()) {
                    int newUserId = generatedKeys.getInt(1);

                    ajouterPointsBienvenue(conn, newUserId);
                    boolean emailEnvoye = sendWelcomeEmail(email, nom, BONUS_POINTS);
                    enregistrerHistoriqueInscription(conn, newUserId);

                    System.out.println("✅ Email de bienvenue envoyé: " + (emailEnvoye ? "Oui" : "Non"));
                }

                showLoadingState(false);
                showSuccessMessage("✓ Inscription réussie !");

                // === PROPOSER L'ENREGISTREMENT FACE ID ===
                proposerEnregistrementFaceID(newUserId, nom);
            }

        } catch (SQLException e) {
            showLoadingState(false);
            String errorMessage = e.getMessage();
            if (errorMessage.contains("Duplicate entry") || errorMessage.contains("duplicate")) {
                showAlertWithLogo(Alert.AlertType.ERROR, "📧 Email déjà utilisé",
                        "Cet email est déjà associé à un compte.");
            } else {
                showAlertWithLogo(Alert.AlertType.ERROR, "❌ Erreur",
                        "Une erreur s'est produite lors de l'inscription.\n\n" + e.getMessage());
            }
            e.printStackTrace();
        }
    }

    private void proposerEnregistrementFaceID(int userId, String nom) {
        Dialog<ButtonType> dialog = new Dialog<>();
        dialog.setTitle("🔐 Configuration Face ID");
        dialog.initStyle(StageStyle.TRANSPARENT);

        VBox content = new VBox(25);
        content.setAlignment(Pos.CENTER);
        content.setPadding(new Insets(40));
        content.setStyle(
                "-fx-background-color: linear-gradient(from 0% 0% to 100% 100%, #F5F5DC, #E8D9C5);" +
                        "-fx-background-radius: 30;" +
                        "-fx-border-color: #8B1E1E;" +
                        "-fx-border-width: 3;" +
                        "-fx-border-radius: 30;" +
                        "-fx-effect: dropshadow(gaussian, #8B1E1E, 30, 0.5, 0, 15);"
        );
        content.setPrefWidth(450);

        Label iconLabel = new Label("🔐");
        iconLabel.setStyle("-fx-font-size: 70px; -fx-text-fill: #8B1E1E;");

        Label titleLabel = new Label("Sécurisez votre compte !");
        titleLabel.setStyle("-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #5D2E2E;");

        Label messageLabel = new Label(
                "Voulez-vous ajouter la reconnaissance faciale " +
                        "pour vous connecter plus facilement ?"
        );
        messageLabel.setWrapText(true);
        messageLabel.setStyle("-fx-font-size: 16px; -fx-text-fill: #8B4513; -fx-text-alignment: center;");

        VBox avantagesBox = new VBox(10);
        avantagesBox.setPadding(new Insets(15));
        avantagesBox.setStyle("-fx-background-color: rgba(139,30,30,0.1); -fx-background-radius: 15;");

        Label avantagesTitle = new Label("✨ Avantages :");
        avantagesTitle.setStyle("-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #8B1E1E;");

        Label av1 = new Label("✓ Connexion plus rapide");
        av1.setStyle("-fx-font-size: 13px; -fx-text-fill: #5D2E2E;");

        Label av2 = new Label("✓ Plus besoin de mot de passe");
        av2.setStyle("-fx-font-size: 13px; -fx-text-fill: #5D2E2E;");

        Label av3 = new Label("✓ Sécurité renforcée");
        av3.setStyle("-fx-font-size: 13px; -fx-text-fill: #5D2E2E;");

        avantagesBox.getChildren().addAll(avantagesTitle, av1, av2, av3);

        content.getChildren().addAll(iconLabel, titleLabel, messageLabel, avantagesBox);

        ButtonType ouiButton = new ButtonType("✅ Oui, configurer Face ID", ButtonBar.ButtonData.OK_DONE);
        ButtonType nonButton = new ButtonType("⏳ Plus tard", ButtonBar.ButtonData.CANCEL_CLOSE);

        dialog.getDialogPane().getButtonTypes().addAll(ouiButton, nonButton);
        dialog.getDialogPane().setContent(content);
        dialog.getDialogPane().setBackground(Background.EMPTY);

        dialog.setOnShowing(e -> {
            Button oui = (Button) dialog.getDialogPane().lookupButton(ouiButton);
            Button non = (Button) dialog.getDialogPane().lookupButton(nonButton);

            if (oui != null) {
                oui.setStyle(
                        "-fx-background-color: linear-gradient(from 0% 0% to 100% 0%, #8B1E1E, #5D2E2E);" +
                                "-fx-text-fill: #F5F5DC;" +
                                "-fx-font-weight: bold;" +
                                "-fx-font-size: 14px;" +
                                "-fx-padding: 12 25;" +
                                "-fx-background-radius: 25;" +
                                "-fx-cursor: hand;" +
                                "-fx-effect: dropshadow(gaussian, #8B1E1E, 8, 0.5, 0, 2);"
                );
            }
            if (non != null) {
                non.setStyle(
                        "-fx-background-color: transparent;" +
                                "-fx-text-fill: #8B1E1E;" +
                                "-fx-font-weight: bold;" +
                                "-fx-font-size: 14px;" +
                                "-fx-padding: 12 25;" +
                                "-fx-background-radius: 25;" +
                                "-fx-border-color: #8B1E1E;" +
                                "-fx-border-width: 2;" +
                                "-fx-cursor: hand;"
                );
            }
        });

        Optional<ButtonType> result = dialog.showAndWait();

        if (result.isPresent() && result.get() == ouiButton) {
            ouvrirConfigurationFaceID(userId, nom);
        } else {
            showSuccessSplash(nom, this::retourLogin);
        }
    }

    // ========== NOUVELLE MÉTHODE POUR OUVRIR LA CONFIGURATION FACE ID ==========
    private void ouvrirConfigurationFaceID(int userId, String nom) {
        try {
            FXMLLoader loader = new FXMLLoader(
                    getClass().getResource("/x404/kouldyeri/view/FaceIDView.fxml")
            );
            Parent root = loader.load();

            FaceIDController controller = loader.getController();
            controller.setEnrollmentMode(userId, nom);

            Stage stage = (Stage) nomField.getScene().getWindow();

            FadeTransition fadeOut = new FadeTransition(Duration.millis(300), stage.getScene().getRoot());
            fadeOut.setFromValue(1.0);
            fadeOut.setToValue(0.0);
            fadeOut.setOnFinished(e -> {
                stage.setScene(new Scene(root));
                stage.setTitle("KoulDyeri - Configuration Face ID");
                stage.centerOnScreen();

                FadeTransition fadeIn = new FadeTransition(Duration.millis(300), stage.getScene().getRoot());
                fadeIn.setFromValue(0.0);
                fadeIn.setToValue(1.0);
                fadeIn.play();
            });
            fadeOut.play();

        } catch (Exception e) {
            e.printStackTrace();
            showAlertWithLogo(Alert.AlertType.ERROR, "❌ Erreur",
                    "Impossible d'ouvrir la configuration Face ID.");
        }
    }

    private void ajouterPointsBienvenue(Connection conn, int userId) throws SQLException {
        String insertPoints = "INSERT INTO PointsSolde (idUtilisateur, solde) VALUES (?, ?)";
        try (PreparedStatement pstPoints = conn.prepareStatement(insertPoints)) {
            pstPoints.setInt(1, userId);
            pstPoints.setInt(2, BONUS_POINTS);
            pstPoints.executeUpdate();
            System.out.println("✅ " + BONUS_POINTS + " points de bienvenue ajoutés pour l'utilisateur ID: " + userId);
        } catch (SQLException e) {
            insertPoints = "INSERT INTO pointssolde (idUtilisateur, solde) VALUES (?, ?)";
            try (PreparedStatement pstPoints = conn.prepareStatement(insertPoints)) {
                pstPoints.setInt(1, userId);
                pstPoints.setInt(2, BONUS_POINTS);
                pstPoints.executeUpdate();
                System.out.println("✅ " + BONUS_POINTS + " points de bienvenue ajoutés pour l'utilisateur ID: " + userId);
            }
        }
    }

    private void enregistrerHistoriqueInscription(Connection conn, int userId) {
        String query = "INSERT INTO historique_inscriptions (user_id, date_inscription) VALUES (?, NOW())";
        try (PreparedStatement pst = conn.prepareStatement(query)) {
            pst.setInt(1, userId);
            pst.executeUpdate();
        } catch (SQLException e) {
            // Ignorer si la table n'existe pas
        }
    }

    private void showLoadingState(boolean loading) {
        if (loading) {
            btnInscription.setText("⏳ Inscription en cours...");
            btnInscription.setDisable(true);
        } else {
            btnInscription.setText("✅ S'inscrire");
            btnInscription.setDisable(false);
        }
    }

    private void showSuccessMessage(String message) {
        messageLabel.setGraphic(createLogoIcon());
        messageLabel.setText(message);
        messageLabel.setStyle("-fx-text-fill: #51cf66; -fx-font-weight: bold;");
        messageLabel.setGraphicTextGap(8);
    }

    private boolean emailExiste(String email) {
        try (Connection conn = DBConnection.getConnection()) {
            String sql = "SELECT COUNT(*) FROM utilisateur WHERE email = ?";
            PreparedStatement pst = conn.prepareStatement(sql);
            pst.setString(1, email);

            ResultSet rs = pst.executeQuery();
            if (rs.next()) {
                return rs.getInt(1) > 0;
            }
        } catch (Exception e) {
            e.printStackTrace();
        }
        return false;
    }

    private boolean validerAge(LocalDate dateNaissance) {
        if (dateNaissance == null) return false;

        LocalDate aujourdhui = LocalDate.now();
        int age = aujourdhui.getYear() - dateNaissance.getYear();

        if (dateNaissance.plusYears(age).isAfter(aujourdhui)) {
            age--;
        }

        return age >= 13 && age <= 120;
    }

    private void showAlertWithLogo(Alert.AlertType type, String title, String message) {
        Alert alert = new Alert(type);
        alert.setTitle(title);
        alert.setHeaderText(null);

        VBox mainContainer = new VBox(20);
        mainContainer.setAlignment(Pos.CENTER);
        mainContainer.setPadding(new Insets(30, 40, 30, 40));
        mainContainer.setStyle("-fx-background-color: white; -fx-background-radius: 15;");

        VBox headerBox = new VBox(15);
        headerBox.setAlignment(Pos.CENTER);

        try {
            Image logoImage = loadLogo();
            if (logoImage != null) {
                ImageView logoView = new ImageView(logoImage);
                logoView.setFitWidth(60);
                logoView.setFitHeight(60);
                logoView.setPreserveRatio(true);
                headerBox.getChildren().add(logoView);
            }
        } catch (Exception e) {
            System.err.println("Impossible de charger le logo: " + e.getMessage());
        }

        Label iconLabel = new Label();
        String iconColor = "";
        switch (type) {
            case ERROR:
                iconLabel.setText("❌");
                iconColor = "#e50914";
                break;
            case WARNING:
                iconLabel.setText("⚠️");
                iconColor = "#ffa500";
                break;
            case INFORMATION:
                iconLabel.setText("✅");
                iconColor = "#51cf66";
                break;
        }
        iconLabel.setStyle("-fx-font-size: 40px; -fx-text-fill: " + iconColor + ";");
        headerBox.getChildren().add(iconLabel);

        Label titleLabel = new Label(title);
        titleLabel.setStyle("-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #1a1a1a;");
        headerBox.getChildren().add(titleLabel);

        mainContainer.getChildren().add(headerBox);

        Region separator = new Region();
        separator.setPrefHeight(1);
        separator.setStyle("-fx-background-color: linear-gradient(to right, transparent, #e0e0e0, transparent);");
        mainContainer.getChildren().add(separator);

        Label messageLabel = new Label(message);
        messageLabel.setWrapText(true);
        messageLabel.setMaxWidth(400);
        messageLabel.setStyle("-fx-font-size: 14px; -fx-text-fill: #333333; -fx-line-spacing: 5px;");
        messageLabel.setAlignment(Pos.CENTER);
        mainContainer.getChildren().add(messageLabel);

        alert.getDialogPane().setContent(mainContainer);
        alert.getDialogPane().setStyle("-fx-background-color: transparent; -fx-background-radius: 15;");

        ButtonType okButton = new ButtonType("✓ OK", ButtonBar.ButtonData.OK_DONE);
        alert.getButtonTypes().setAll(okButton);

        alert.setOnShowing(e -> {
            Button ok = (Button) alert.getDialogPane().lookupButton(okButton);
            if (ok != null) {
                ok.setStyle(
                        "-fx-background-color: linear-gradient(to right, #CE1126, #8B0000); " +
                                "-fx-text-fill: white; " +
                                "-fx-font-weight: bold; " +
                                "-fx-font-size: 14px; " +
                                "-fx-padding: 10 30; " +
                                "-fx-background-radius: 20; " +
                                "-fx-cursor: hand;"
                );
            }
        });

        alert.showAndWait();
    }

    @FXML
    private void retourLogin() {
        try {
            Parent root = FXMLLoader.load(
                    getClass().getResource("/x404/kouldyeri/view/LoginView.fxml"));
            Stage stage = (Stage) nomField.getScene().getWindow();

            FadeTransition fadeOut = new FadeTransition(Duration.millis(300), stage.getScene().getRoot());
            fadeOut.setFromValue(1.0);
            fadeOut.setToValue(0.0);
            fadeOut.setOnFinished(e -> {
                stage.setScene(new Scene(root));
                stage.setTitle("KoulDyeri - Connexion");
                stage.centerOnScreen();

                FadeTransition fadeIn = new FadeTransition(Duration.millis(300), stage.getScene().getRoot());
                fadeIn.setFromValue(0.0);
                fadeIn.setToValue(1.0);
                fadeIn.play();
            });
            fadeOut.play();

        } catch (Exception e) {
            e.printStackTrace();
        }
    }

    @FXML
    private void annuler() {
        retourLogin();
    }

    private static class ValidationResult {
        private final boolean valid;
        private final String errorMessage;

        public ValidationResult(boolean valid, String errorMessage) {
            this.valid = valid;
            this.errorMessage = errorMessage;
        }

        public boolean isValid() {
            return valid;
        }

        public String getErrorMessage() {
            return errorMessage;
        }
    }
}